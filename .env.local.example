# --- WhatsApp Business / Meta Cloud API ---
# Permanent or temporary access token from Meta App Dashboard
WHATSAPP_TOKEN=
# The Phone Number ID (NOT the phone number) from WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
# Any random string you invent; you paste the same value into Meta's webhook config
WHATSAPP_VERIFY_TOKEN=
# Your personal WhatsApp number (E.164, no '+'), e.g. 9613xxxxxxx.
# Drafts are sent here for approval before forwarding to the original sender.
WHATSAPP_OWNER_NUMBER=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
